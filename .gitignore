# Smicolon Claude Code Infrastructure
# Git ignore file

# Local development
.DS_Store
*.swp
*.swo
*~

# Test directories
test/
tmp/
*.tmp

# Dependencies
node_modules/

# Build artifacts
dist/
*.tar.gz
*.zip

# Local-only files (personal settings, session data)
**/*.local.*
**/*.local.md

# Speckit - ignore local directory
.specify/

# OS files
Thumbs.db
.directory

# IDE
.vscode/
.idea/
*.sublime-*

# Logs
*.log

# Agent artifacts (local planning/progress files)
agent-artifacts/

# Ignore claude-mem generated files
packs/**/CLAUDE.md
.claude-plugin/CLAUDE.md

# AI coding tools (managed by @smicolon/ai-kit)
.ai-kit.json