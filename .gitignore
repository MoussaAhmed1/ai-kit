# Smicolon Claude Code Infrastructure
# Git ignore file

# Local development
.DS_Store
*.swp
*.swo
*~

# Test directories
test/
tmp/
*.tmp

# Dependencies
node_modules/

# Build artifacts
dist/
*.tar.gz
*.zip

# Claude Code - ignore local directory entirely
.claude/

# Speckit - ignore local directory
.specify/

# OS files
Thumbs.db
.directory

# IDE
.vscode/
.idea/
*.sublime-*

# Logs
*.log

# Agent artifacts (local planning/progress files)
agent-artifacts/

# Ignore claude-mem generated files inside plugins
packs/**/CLAUDE.md
