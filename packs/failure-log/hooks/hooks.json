{
  "description": "Failure log hooks for injecting learned lessons at session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-failures.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
