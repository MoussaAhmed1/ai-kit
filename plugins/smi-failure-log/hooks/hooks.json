{
  "description": "Failure log hooks for capturing mistakes and injecting learned lessons",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-failures.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
